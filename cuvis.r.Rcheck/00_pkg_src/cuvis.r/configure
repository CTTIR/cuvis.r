#!/bin/bash

# configure script for cuvis.r
# Locates the Cubert CUVIS SDK headers and library

echo "* Configuring cuvis.r ..."

CUVIS_INCLUDE=""
CUVIS_LIB=""
CUVIS_LIBNAME="cuvis"

# 1. Check CUVIS_SDK environment variable
if [ -n "$CUVIS_SDK" ]; then
  echo "  - Checking CUVIS_SDK=$CUVIS_SDK"
  if [ -d "$CUVIS_SDK/include" ]; then
    CUVIS_INCLUDE="$CUVIS_SDK/include"
  fi
  if [ -d "$CUVIS_SDK/lib" ]; then
    CUVIS_LIB="$CUVIS_SDK/lib"
  elif [ -d "$CUVIS_SDK/lib64" ]; then
    CUVIS_LIB="$CUVIS_SDK/lib64"
  fi
fi

# 2. Check CUVIS environment variable (Windows convention)
if [ -z "$CUVIS_INCLUDE" ] && [ -n "$CUVIS" ]; then
  echo "  - Checking CUVIS=$CUVIS"
  if [ -d "$CUVIS/include" ]; then
    CUVIS_INCLUDE="$CUVIS/include"
  fi
  if [ -d "$CUVIS/lib" ]; then
    CUVIS_LIB="$CUVIS/lib"
  fi
fi

# 3. Search common install locations
if [ -z "$CUVIS_INCLUDE" ]; then
  for dir in /opt/cuvis /usr/local/cuvis /usr/local "C:/Program Files/Cubert GmbH/Cuvis"; do
    if [ -f "$dir/include/cuvis.h" ]; then
      echo "  - Found SDK in $dir"
      CUVIS_INCLUDE="$dir/include"
      if [ -d "$dir/lib" ]; then
        CUVIS_LIB="$dir/lib"
      elif [ -d "$dir/lib64" ]; then
        CUVIS_LIB="$dir/lib64"
      fi
      break
    fi
  done
fi

# 4. Check .cuvis/ in package root for development
if [ -z "$CUVIS_INCLUDE" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  FOUND=$(find "$SCRIPT_DIR/.cuvis" -name "cuvis.h" -type f 2>/dev/null | head -1)
  if [ -n "$FOUND" ]; then
    CUVIS_INCLUDE="$(dirname "$FOUND")"
    PARENT="$(dirname "$CUVIS_INCLUDE")"
    if [ -d "$PARENT/lib" ]; then
      CUVIS_LIB="$PARENT/lib"
    elif [ -d "$PARENT/lib64" ]; then
      CUVIS_LIB="$PARENT/lib64"
    fi
    echo "  - Found SDK in .cuvis/ development directory"
  fi
fi

# Check if we found the header
if [ -n "$CUVIS_INCLUDE" ] && [ -f "$CUVIS_INCLUDE/cuvis.h" ]; then
  echo "  - CUVIS SDK headers: $CUVIS_INCLUDE"
  echo "  - CUVIS SDK library: $CUVIS_LIB"

  # Check for library name
  if [ -f "$CUVIS_LIB/libcuvis_c.so" ] || [ -f "$CUVIS_LIB/libcuvis_c.dylib" ] || [ -f "$CUVIS_LIB/cuvis_c.dll" ]; then
    CUVIS_LIBNAME="cuvis_c"
  fi

  # Write Makevars
  sed -e "s|@CUVIS_INCLUDE@|$CUVIS_INCLUDE|g" \
      -e "s|@CUVIS_LIB@|$CUVIS_LIB|g" \
      -e "s|@CUVIS_LIBNAME@|$CUVIS_LIBNAME|g" \
      src/Makevars.in > src/Makevars

  echo "* Configuration complete."
else
  echo ""
  echo "---------------------------------------------------------------"
  echo "NOTE: Cubert CUVIS SDK not found."
  echo ""
  echo "The package will be installed with stub C functions only."
  echo "Full SDK functionality requires the CUVIS SDK."
  echo ""
  echo "Install the SDK from:"
  echo "  https://cloud.cubert-gmbh.de/s/qpxkyWkycrmBK9m"
  echo ""
  echo "Then reinstall cuvis.r with CUVIS_SDK set:"
  echo "  export CUVIS_SDK=/path/to/cuvis/sdk"
  echo "  Rscript -e 'remotes::install_github(\"r-heller/cuvis.r\")'"
  echo "---------------------------------------------------------------"
  echo ""

  # Write Makevars with stubs (no SDK linking)
  cat > src/Makevars <<'MAKEVARS_EOF'
PKG_CPPFLAGS = -DCUVIS_STUB
PKG_LIBS =
MAKEVARS_EOF

  echo "* Configuration complete (stub mode)."
fi
